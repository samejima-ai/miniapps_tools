{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm run dev*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm run typecheck*)",
      "Bash(pnpm run check:ssot*)",
      "Bash(pnpm run check:design-tokens*)",
      "Bash(rg*)",
      "Bash(grep*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(supabase*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(* DROP TABLE*)",
      "Bash(* DELETE FROM miniapps_tools.item_movements*)"
    ]
  },
  "env": {
    "PNPM_HOME": "/root/.local/share/pnpm"
  }
}
